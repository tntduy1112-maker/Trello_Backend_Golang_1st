# ============================================
# Trello Agent — Environment Variables
# ============================================
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control
# ============================================

# ==========================================
# Application
# ==========================================
APP_NAME=trello-agent
APP_ENV=development                    # development | staging | production
APP_PORT=8080
APP_URL=http://localhost:8080
LOG_LEVEL=debug                        # debug | info | warn | error

# ==========================================
# Frontend (for CORS and email links)
# ==========================================
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================
# Database (PostgreSQL)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=trello_agent
DB_PASSWORD=trello_agent_secret
DB_NAME=trello_agent
DB_SSLMODE=disable
DATABASE_URL=postgres://trello_agent:trello_agent_secret@localhost:5432/trello_agent?sslmode=disable
DB_POOL_MAX=10

# ==========================================
# Redis
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ==========================================
# JWT Authentication
# ==========================================
# IMPORTANT: Generate strong secrets for production!
# Use: openssl rand -base64 32
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h                # 7 days

# ==========================================
# AES Encryption (for cookies)
# ==========================================
# Must be exactly 32 bytes for AES-256
# Use: openssl rand -base64 32 | head -c 32
AES_KEY=32-byte-secret-key-for-aes256!

# ==========================================
# MinIO (S3-compatible storage)
# ==========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=trello-agent
MINIO_USE_SSL=false
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ==========================================
# Email (SMTP)
# ==========================================
SMTP_HOST=localhost                    # Use mailhog for development
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@trello-agent.local
SMTP_TLS=false

# MailHog (development email testing)
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_LOGIN=5                     # requests per 15 minutes per IP
RATE_LIMIT_REGISTER=3                  # requests per hour per IP
RATE_LIMIT_API=100                     # requests per minute per user

# ==========================================
# File Upload
# ==========================================
MAX_FILE_SIZE=10485760                 # 10MB in bytes
MAX_AVATAR_SIZE=2097152                # 2MB in bytes
ALLOWED_FILE_TYPES=image/*,application/pdf,application/zip

# ==========================================
# Background Jobs (Asynq)
# ==========================================
ASYNQ_REDIS_URL=redis://:redis_secret@localhost:6379/1
ASYNQ_CONCURRENCY=10

# ==========================================
# Docker Compose Ports (for local dev)
# ==========================================
API_PORT=8080
# DB_PORT=5432      # already defined above
# REDIS_PORT=6379   # already defined above
# MINIO_PORT=9000   # already defined above

# ==========================================
# Production Only
# ==========================================
# DOCKER_REGISTRY=ghcr.io/your-org
# VERSION=latest
# SENTRY_DSN=https://xxx@sentry.io/xxx
# PROMETHEUS_ENABLED=true
